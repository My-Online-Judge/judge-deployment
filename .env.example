# ============================================================================
# Template for judge-deployment/.env — copy to .env and fill in the secrets.
#   cp .env.example .env
# Container-network addresses (db / kafka:29092 / judge-server) — keep as-is unless
# you rename services.
# ============================================================================

# ---- spring profile (judge-api) ----
# "prod" runs judge-api against Postgres with ddl-auto=update and swagger disabled.
SPRING_PROFILES_ACTIVE=prod

# ---- shared judge-server auth/token (api, worker, judge-server all agree) ----
JUDGE_SERVER_TOKEN=change-me
# The worker accepts a COMMA-SEPARATED list of judge-server URLs and round-robins across them
# with failover (skips a dead sandbox / 5xx and tries the next). To run more than one sandbox,
# add another judge-server service and list both, e.g.:
#   JUDGE_SERVER_URL=http://judge-server:8080,http://judge-server-2:8080
JUDGE_SERVER_URL=http://judge-server:8080,http://judge-server-2:8080

# ---- database ----
DATABASE_URL=jdbc:postgresql://db:5432/my_oj
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=change-me
DATABASE_NAME=my_oj

# ---- kafka (internal KRaft listener) ----
KAFKA_BROKERS=kafka:29092

# ---- redis (verdict SSE fan-out across judge-api instances) ----
REDIS_HOST=redis
REDIS_PORT=6379

# ---- jwt (legacy HS256 secret — see the cutover note below) ----
# FRESH INSTALLS: leave this EMPTY. It exists only to keep pre-RS256 tokens
# verifying during the cutover window; setting it on a new stack arms the HS256
# fallback permanently for no reason. Only an existing stack mid-cutover needs it.
JWT_SECRET_KEY=
JWT_ACCESS_TOKEN_EXPIRATION=86400000
JWT_REFRESH_TOKEN_EXPIRATION=259200000

# --- RS256 JWT signing (T4-9b) ---------------------------------------------
# Tokens are signed RS256 with an asymmetric keypair: only the holder of the
# private key can MINT a token, so a leaked verification key is harmless (the
# old symmetric secret let anyone who read it forge tokens).
#
# Generate the keypair ONCE, then paste the base64 of each whole PEM file:
#   openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 -out jwt-rsa.pem
#   openssl pkey -in jwt-rsa.pem -pubout -out jwt-rsa.pub.pem
#   echo "JWT_RSA_PRIVATE_KEY=$(base64 -w0 jwt-rsa.pem)"
#   echo "JWT_RSA_PUBLIC_KEY=$(base64 -w0 jwt-rsa.pub.pem)"
# Then delete jwt-rsa.pem / jwt-rsa.pub.pem — this .env is their only home.
# (-w0 keeps the value on one line, which is what a .env wants. The loader is
# whitespace-tolerant, but a wrapped value spanning lines still breaks .env parsing.)
#
# Both vars are REQUIRED: judge-api refuses to boot if either is missing,
# unparseable, or if the two keys are not a matching pair.
JWT_RSA_PRIVATE_KEY=
JWT_RSA_PUBLIC_KEY=

# CUTOVER (two steps, nobody gets logged out):
#
#   !! Use `up -d`, NOT `restart`. `docker compose restart` reuses the existing
#   !! container and its baked-in environment, so an edited .env has NO effect --
#   !! the app comes up healthy and you would believe the cutover happened while
#   !! the legacy HMAC secret stays live indefinitely. Only `up -d` recreates the
#   !! container with the new env_file. Always verify with the grep line below.
#
#   1. Add the two JWT_RSA_* vars above, KEEP JWT_SECRET_KEY, then:
#        docker compose up -d judge-api
#      All new tokens are RS256; existing HS256 tokens still verify via the
#      fallback. Access tokens turn over within JWT_ACCESS_TOKEN_EXPIRATION,
#      refresh tokens within JWT_REFRESH_TOKEN_EXPIRATION (3 days by default).
#
#   2. After AT LEAST JWT_REFRESH_TOKEN_EXPIRATION has elapsed (3 days by
#      default -- any earlier and you log out everyone still on an HS256 refresh
#      token), DELETE the JWT_SECRET_KEY line above, then:
#        docker compose up -d judge-api
#        docker compose exec judge-api env | grep JWT_SECRET_KEY   # must print NOTHING
#      If that grep prints anything, the container was not recreated and HS256 is
#      still accepted -- rerun `up -d` (add --force-recreate if needed).
#      Once it prints nothing, HS256 is rejected outright: no code change needed,
#      because an absent/empty secret is what switches the fallback off.

# --- MinIO (test-case object storage, T3-8) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=test-cases

# ---- google oauth (backend-owned callback) ----
# The API exchanges the code server-side and sets HttpOnly cookies, then returns the browser
# to APP_BASE_URL. Register GOOGLE_REDIRECT_URI (the API callback) in the Google console.
# Move the SPA between origins by changing only APP_BASE_URL — no console edit needed.
APP_BASE_URL=http://localhost
# COOKIE_SECURE=true only behind HTTPS (prod); false for a plain http://localhost stack.
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/outbound/google/callback
GOOGLE_AUTH_URI=https://accounts.google.com/o/oauth2/auth
GOOGLE_TOKEN_URI=https://oauth2.googleapis.com/token
GOOGLE_USER_INFO_URI=https://www.googleapis.com/oauth2/v3/userinfo
